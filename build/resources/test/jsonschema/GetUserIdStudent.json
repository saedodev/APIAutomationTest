{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "nama": { "type": "string" },
              "nis": { "type": "string" },
              "kelas": { "type": "string" },
              "jurusan": { "type": "string" },
              "email": { "type": ["string", "null"] },
              "telepon": { "type": ["string", "null"] },
              "alamat": { "type": ["string", "null"] },
              "created_by": { "type": "string" },
              "created_at": { "type": "string" },
              "updated_at": { "type": "string" }
            },
            "required": [
              "id", "nama", "nis", "kelas", "jurusan",
              "email", "telepon", "alamat",
              "created_by", "created_at", "updated_at"
            ]
          }
        },
        "pagination": {
          "type": "object",
          "properties": {
            "page": { "type": "integer" },
            "limit": { "type": "integer" },
            "total": { "type": "integer" },
            "totalPages": { "type": "integer" }
          },
          "required": ["page", "limit", "total", "totalPages"]
        }
      },
      "required": ["data", "pagination"]
    }
  },
  "required": ["success", "data"]
}